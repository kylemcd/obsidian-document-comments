{
	"name": "document-comments",
	"version": "0.1.11",
	"description": "Notion-style margin comments for Obsidian, stored inline in markdown.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "node node_modules/typescript-7/bin/tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"typecheck": "node node_modules/typescript-7/bin/tsc -noEmit -skipLibCheck",
		"format": "oxfmt src test",
		"format:check": "oxfmt --check src test",
		"lint": "oxlint src test && eslint src package.json",
		"lint:fix": "oxlint src test --fix && eslint src package.json --fix",
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "npm run format:check && npm run lint && npm run typecheck && npm test"
	},
	"keywords": [
		"obsidian-plugin"
	],
	"author": "Kyle McDonald",
	"license": "MIT",
	"devDependencies": {
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.43.6",
		"@types/node": "^26.1.1",
		"esbuild": "^0.28.1",
		"eslint": "^10.7.0",
		"eslint-plugin-obsidianmd": "^0.4.1",
		"happy-dom": "^20.10.6",
		"obsidian": "^1.5.7",
		"oxfmt": "^0.59.0",
		"oxlint": "^1.73.0",
		"typescript": "^6.0.3",
		"typescript-7": "npm:typescript@^7.0.2",
		"typescript-eslint": "^8.63.0",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"better-result": "^2.9.2"
	}
}
